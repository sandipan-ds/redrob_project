# .dockerignore — keep the build context small.
#
# The image only needs: src/, config/, models/all-MiniLM-L6-v2/,
# artifacts/sample/, data/samples/, app.py, requirements.txt, README.md.
# Everything else is dev/test/docs and should be excluded.

# --- Dev caches ---
.git/
.gitignore
.gitattributes
__pycache__/
*.pyc
*.pyo
.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- OS / IDE ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# --- Test artifacts ---
tests/
pytest.ini
.coverage
htmlcov/

# --- Docs (not needed at runtime) ---
docs/
*.md
!README.md
AGENTS.md

# --- Data: only the sample is in the image; originals are gitignored ---
data/originals/
data/originals.zip
data/originals.tar.gz
notebooks/

# --- Outputs ---
outputs/
*.csv
!data/samples/sample_candidates.json

# --- Production precompute (~440 MB, regenerated locally) ---
artifacts/full/

# --- Dev scripts (not needed at runtime) ---
scripts/
push_to_hf.sh
smoke_test_app.py
docker_build.log
*.err
*.log

# --- Build artifacts ---
dist/
build/
*.tar
*.zip

# --- CI ---
.github/
.gitlab-ci.yml
